# Configuration de l'API Google Sheets
# 
# Fichier: .env.example (À copier en .env et à compléter)
# 
# ⚠️ NE PAS commit ce fichier dans git s'il contient des vraies clés!

# 1. URL de votre Google Apps Script (OBLIGATOIRE)
# Trouvez-la dans Apps Script > Deploy > New deployment > Copy Web app URL
APPS_SCRIPT_URL=https://script.google.com/macros/d/YOUR_SCRIPT_ID/userweb

# 2. API Key pour Google Apps Script (OBLIGATOIRE)
# = le Script ID trouvé ci-dessus (la partie entre /d/ et /userweb)
# Exemple: AKfycbw_1234567890ABCDEFGHIJKLMNOP
APPS_SCRIPT_API_KEY=wifaq_mo94so99ro04ma10

# 3. Mode test (optionnel)
# Mettez "true" pour tester sans configuration réelle
TEST_MODE=false

# 4. Debug logging (optionnel)
# Mettez "true" pour voir plus de logs en debug
DEBUG_CLOUD_SYNC=false
